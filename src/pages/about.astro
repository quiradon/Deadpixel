---
import Layout from '../layouts/Layout.astro';
import { loadT } from '../lib/i18n';
import { getLocale } from "astro-i18n-aut";

const locale = getLocale(Astro.url);
const t = loadT(locale);

const pageTitle = t.footer?.about || "About";
const pageDesc = "Conheça o DeadPixel Studio - Nossa história, missão e a equipe por trás dos jogos.";

const teamMembers = [
  {
    name: "Douglas Rodrigues",
    role: "Sound Designer",
    photo: "/img/about/douglas.webp"
  },
  {
    name: "Ivy Rantichieri",
    role: "Digital Artist",
    photo: "/img/about/eve.webp"
  },
  {
    name: "Alan Sol",
    role: "Tech Artist",
    photo: "/img/about/sol.webp"
  },
  {
    name: "Rogers",
    role: "Digital Artist",
    photo: "/img/about/roger.webp"
  },
  {
    name: "João Victor",
    role: "Lead Programmer",
    photo: "/img/about/joao.webp"
  },
  {
    name: "Arthur Câmara",
    role: "Game Designer",
    photo: "/img/about/Arthur.webp"
  },
  {
    name: "Arthur Araújo",
    role: "Community Manager",
    photo: "/img/about/araujo.webp"
  }
];
---

<Layout 
  t={t}
  title={pageTitle} 
  desc={pageDesc}
>
  <main class="about-page">
    <!-- Section 1: Hero com título, parágrafo e imagem -->
    <section class="hero-section py-5">
      <div class="container">
        <div class="row align-items-center g-5">
       <div class="col-lg-6 order-lg-2">
<!--            <div class="image-wrapper">
              <img 
                src="/img/about/studio.jpg" 
                alt="DeadPixel Studio" 
                class="img-fluid rounded-4 shadow-lg"
              />
            </div> -->
          </div> 
          <div class="col-lg-6 order-lg-1">
            <h1 class="display-4 fw-bold mb-4 gradient-text">
              {t.footer?.about || "About"} DeadPixel Studio
            </h1>
            <p class="lead mb-4">
              {t.about[0]}
            </p>
            <p class="text-secondary mb-4">
              {t.about[1]}
            </p>
            <div class="stats-row d-flex gap-4 flex-wrap">
              <div class="stat-item">
                <h3 class="text-primary mb-0">5+</h3>
                <p class="text-muted small mb-0">{t.about[2]}</p>
              </div>
              <div class="stat-item">
                <h3 class="text-primary mb-0">10+</h3>
                <p class="text-muted small mb-0">{t.about[3]}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Time -->
    <section class="team-section py-5">
      <div class="container">
        <div class="text-center mb-5">
          <h2 class="display-5 fw-bold mb-3 gradient-text">{t.about[4]}</h2>
          <p class="lead text-secondary">
            {t.about[5]}
          </p>
        </div>
        
        <div class="row g-4">
          {teamMembers.map((member) => (
            <div class="col-md-6 col-lg-4 col-xl-3">
              <div class="team-card">
                <div class="team-card-image">
                  <img 
                    src={member.photo} 
                    alt={member.name}
                    class="img-fluid"
                  />
                </div>
                <div class="team-card-content">
                  <h3 class="h5 mb-1">{member.name}</h3>
                  <p class="text-primary small mb-0">{member.role}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 3: Nossa Visão -->
    <section class="vision-section py-5">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-lg-8">
            <div class="vision-content text-center">
              <h2 class="display-5 fw-bold mb-4 gradient-text">{t.about[6]}</h2>
              <p class="lead mb-4">
                {t.about[7]}
              </p>
              <p class="text-secondary mb-4">
                {t.about[8]}
              </p>
              <p class="text-secondary mb-5">
                {t.about[9]}
              </p>
              <div class="cta-buttons d-flex gap-3 justify-content-center flex-wrap">
                <a href="/#games" class="btn btn-primary btn-lg px-5">
                  {t.view_games}
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .about-page {
    min-height: 100vh;
  }

  /* Hero Section */
  .hero-section {
    background: linear-gradient(135deg, rgba(125, 1, 255, 0.05) 0%, rgba(246, 87, 255, 0.05) 100%);
  }

  .gradient-text {
    background: linear-gradient(135deg, #F657FF 0%, #7D01FF 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .image-wrapper {
    position: relative;
    animation: float 6s ease-in-out infinite;
  }

  .image-wrapper::before {
    content: '';
    position: absolute;
    inset: -10px;
    background: linear-gradient(135deg, #F657FF, #7D01FF);
    border-radius: 1.5rem;
    opacity: 0.2;
    filter: blur(20px);
    z-index: -1;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  .stats-row {
    margin-top: 2rem;
  }

  .stat-item h3 {
    font-size: 2.5rem;
    font-weight: 700;
  }

  /* Team Section */
  .team-section {
    background: rgba(11, 9, 16, 0.3);
  }

  .team-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(246, 87, 255, 0.1);
    border-radius: 1rem;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .team-card:hover {
    transform: translateY(-10px);
    border-color: rgba(246, 87, 255, 0.3);
    box-shadow: 0 20px 40px rgba(246, 87, 255, 0.2);
  }

  .team-card-image {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(125, 1, 255, 0.1), rgba(246, 87, 255, 0.1));
  }

  .team-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .team-card:hover .team-card-image img {
    transform: scale(1.05);
  }

  .team-card-content {
    padding: 1.5rem;
    text-align: center;
  }

  /* Vision Section */
  .vision-section {
    background: linear-gradient(135deg, rgba(246, 87, 255, 0.03) 0%, rgba(125, 1, 255, 0.03) 100%);
  }

  .vision-content {
    padding: 2rem;
  }

  .btn-primary {
    background: linear-gradient(135deg, #F657FF, #7D01FF);
    border: none;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(246, 87, 255, 0.4);
  }

  .btn-outline-primary {
    border: 2px solid #F657FF;
    color: #F657FF;
    transition: all 0.3s ease;
  }

  .btn-outline-primary:hover {
    background: linear-gradient(135deg, #F657FF, #7D01FF);
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
  }

  @media (max-width: 991px) {
    .hero-section .order-lg-2 {
      order: 1;
    }
    
    .hero-section .order-lg-1 {
      order: 2;
    }
  }

  /* Scroll suave */
  html {
    scroll-behavior: smooth;
  }
</style>
