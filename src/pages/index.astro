            </svg>
            {t.view_steam}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Machick 2 -->
  <section id="machick2" class="game-detail-section py-5">
    <div class="container">
      <div class="row align-items-center g-5">
        <div class="col-lg-6 order-lg-2">
          <div class="game-detail-image">
            <img src="/img/games/machick2.webp" alt="Machick 2 Gameplay" class="img-fluid rounded-4 shadow-lg" />
          </div>
        </div>
        <div class="col-lg-6 order-lg-1">
          <h2 class="display-5 fw-bold mb-3 gradient-text">Machick 2</h2>
          <p class="lead mb-4">
            {t.machick[5]}
          </p>
          <p class="text-secondary mb-4">
            {t.machick[6]}
          </p>
          <a href="https://store.steampowered.com/app/3449040/Machick_2/" target="_blank" rel="noopener" class="btn btn-primary btn-lg px-5">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24" class="me-2" style="display: inline-block; vertical-align: middle;">
              <path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.454 1.012H7.54zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.663 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.253 0-2.265-1.014-2.265-2.265z"/>
            </svg>
            {t.view_steam}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Bees vs Zombees -->
  <section id="bees-vs-zombees" class="game-detail-section py-5">
    <div class="container">
      <div class="row align-items-center g-5">
        <div class="col-lg-6">
          <div class="game-detail-image">
            <img src="/img/games/bees.webp" alt="Bees vs Zombees Gameplay" class="img-fluid rounded-4 shadow-lg" />
          </div>
        </div>
        <div class="col-lg-6">
          <h2 class="display-5 fw-bold mb-3 gradient-text">Bees vs Zombees</h2>
          <p class="lead mb-4">
            {t.bees[0]}
          </p>
          <p class="text-secondary mb-4">
            {t.bees[1]}
          </p>
          <a href="https://store.steampowered.com/app/3040270/Bees_vs_Zombees/" target="_blank" rel="noopener" class="btn btn-primary btn-lg px-5">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24" class="me-2" style="display: inline-block; vertical-align: middle;">
              <path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.454 1.012H7.54zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.663 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.253 0-2.265-1.014-2.265-2.265z"/>
            </svg>
            {t.view_steam}
          </a>
        </div>
      </div>
    </div>
  </section>
  </Layout>

<style>
  .gradient-text {
    background: linear-gradient(135deg, #F657FF 0%, #7D01FF 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .game-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .game-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(246, 87, 255, 0.1);
    border-radius: 1rem;
    overflow: hidden;
    transition: all 0.3s ease;
    height: 100%;
  }

  .game-card:hover {
    transform: translateY(-10px);
    border-color: rgba(246, 87, 255, 0.4);
    box-shadow: 0 20px 40px rgba(246, 87, 255, 0.3);
  }

  .game-card-image {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(125, 1, 255, 0.1), rgba(246, 87, 255, 0.1));
  }

  .game-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.3s ease;
  }

  .game-card:hover .game-card-image img {
    transform: scale(1.1);
  }

  .game-card-content {
    padding: 1.5rem;
  }

  .game-detail-section {
    background: linear-gradient(135deg, rgba(246, 87, 255, 0.02) 0%, rgba(125, 1, 255, 0.02) 100%);
  }

  .game-detail-section:nth-child(even) {
    background: linear-gradient(135deg, rgba(125, 1, 255, 0.03) 0%, rgba(246, 87, 255, 0.03) 100%);
  }

  .game-detail-image {
    position: relative;
  }

  .game-detail-image::before {
    content: '';
    position: absolute;
    inset: -10px;
    background: linear-gradient(135deg, #F657FF, #7D01FF);
    border-radius: 1.5rem;
    opacity: 0.2;
    filter: blur(20px);
    z-index: -1;
  }

  .game-detail-image img {
    width: 100%;
    height: auto;
  }

  .btn-primary {
    background: linear-gradient(135deg, #F657FF, #7D01FF);
    border: none;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(246, 87, 255, 0.4);
  }

  .btn-outline-primary {
    border: 2px solid #F657FF;
    color: #F657FF;
    transition: all 0.3s ease;
  }

  .btn-outline-primary:hover {
    background: linear-gradient(135deg, #F657FF, #7D01FF);
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
  }

  /* Scroll suave para âncoras */
  html {
    scroll-behavior: smooth;
  }

  /* Ajuste para compensar navbar fixa */
  section[id] {
    scroll-margin-top: 100px;
  }
</style>


