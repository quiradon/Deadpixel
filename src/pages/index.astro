---
import { Image } from 'astro:assets';
export const prerender = true;
import { getLocale } from "astro-i18n-aut";
import Layout from '@layouts/Layout.astro';
import { loadT} from '@lib/i18n';
import { idiomaR } from '@lib/routes';
import config from '../config.json';
const t = loadT(getLocale(Astro.url));
const langPrefix = idiomaR(t);

const landingHTML = ('Seu estudio de Roguelikes').replace(/\*\*(.*?)\*\*/g, '<span class="text-primary">$1<\/span>');
const sistemas: Record<string, any> = t.posts?.sistemas ?? {};
---
<Layout t={t} title={'DeadPixel Studio'} desc="A Roguelike game studio specializing in innovative gameplay and immersive experiences." pictureURL="/img/bg.webp">
  <head>
    <link rel="preload" as="image" href="/img/bg/pattern-square.svg" type="image/svg+xml">
  </head>
  <!-- Nossos Jogos Section -->
  <section id="games" class="py-5">
    <div class="container">
      <div class="text-center mb-5">
        <h2 class="display-4 fw-bold gradient-text">{t.nossos}</h2>
        <p class="lead text-secondary">{t.nossos_desc}</p>
      </div>

      <!-- Cards dos Jogos -->
      <div class="row g-4 mb-5">
        <div class="col-md-4">
          <a href="#machick1" class="game-card-link">
            <div class="game-card">
              <div class="game-card-image">
                <img src="/img/games/machick1.webp" alt="Machick 1" class="img-fluid" />
              </div>
              <div class="game-card-content">
                <h3 class="h4 mb-2">Machick 1</h3>
                <p class="text-secondary small mb-0">{t.machick[1]}</p>
              </div>
            </div>
          </a>
        </div>

        <div class="col-md-4">
          <a href="#machick2" class="game-card-link">
            <div class="game-card">
              <div class="game-card-image">
                <img src="/img/games/machick2.webp" alt="Machick 2" class="img-fluid" />
              </div>
              <div class="game-card-content">
                <h3 class="h4 mb-2">Machick 2</h3>
                <p class="text-secondary small mb-0">{t.machick[2]}</p>
              </div>
            </div>
          </a>
        </div>

        <div class="col-md-4">
          <a href="#bees-vs-zombees" class="game-card-link">
            <div class="game-card">
              <div class="game-card-image">
                <img src="/img/games/bees.webp" alt="Bees vs Zombees" class="img-fluid" />
              </div>
              <div class="game-card-content">
                <h3 class="h4 mb-2">Bees vs Zombees</h3>
                <p class="text-secondary small mb-0">{t.bees[2]}</p>
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Detalhes dos Jogos -->
  <!-- Machick 1 -->
  <section id="machick1" class="game-detail-section py-5">
    <div class="container">
      <div class="row align-items-center g-5">
        <div class="col-lg-6">
          <div class="game-detail-image">
            <img src="/img/games/machick1.webp" alt="Machick 1 Gameplay" class="img-fluid rounded-4 shadow-lg" />
          </div>
        </div>
        <div class="col-lg-6">
          <h2 class="display-5 fw-bold mb-3 gradient-text">Machick 1</h2>
          <p class="lead mb-4">
            {t.machick[3]}
          </p>
          <p class="text-secondary mb-4">
            {t.machick[4]}
          </p>
          <a href="https://store.steampowered.com/app/2811200/Machick/" target="_blank" rel="noopener" class="btn btn-primary btn-lg px-5">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24" class="me-2" style="display: inline-block; vertical-align: middle;">
